# Mainnet defaults (netuid 110). For testnet monitoring:
#   SUBTENSOR_URL=wss://test.finney.opentensor.ai:443/   # lite testnet (limited historical checks)
#   NETUID=16
#
# IMPORTANT — use an ARCHIVE endpoint, not a lite node.
# Each epoch's commitment OVERWRITES the previous entry in the on-chain
# Commitments map, so historical verification needs state-at-block queries
# that only archive nodes serve. A lite node prunes state after ~256 blocks,
# making any audit run that misses a polling window unable to verify the
# commitments from that gap.
#
# Public archive run by the Opentensor Foundation is free to use:
SUBTENSOR_URL=wss://archive.chain.opentensor.ai:443/
#
# If you prefer self-hosting an archive node, expect ~1TB+ disk and growing.
# Point SUBTENSOR_URL at your own ws://<host>:<port> in that case.
NETUID=110
VALIDATOR_ENDPOINT=https://validator.green-compute.com
AUDIT_INTERVAL_SECONDS=300

# ─── Optional: independent weight setting (Chutes-style) ─────────────────────
#
# When false (DEFAULT), this auditor is purely read-only — verifies SHA256
# anchors, validates ed25519 signatures, replays scoring math. Sends nothing.
# Needs no keys at all.
#
# When true, the auditor publishes its OWN `set_weights` extrinsic to the
# subnet derived from the independently replayed audit data. This shadows
# the audited validator's weight vector with one computed from publicly
# verifiable raw data, so dishonest validators don't dominate weights.
#
# Requirements when enabling:
#   1. Your hotkey must be REGISTERED on this netuid (`btcli subnet register`).
#   2. Your hotkey needs enough stake to receive a validator permit (varies
#      per subnet — check `btcli subnet hyperparameters`).
#   3. AUDITOR_COLDKEY_NAME / AUDITOR_HOTKEY_NAME below must point to a real
#      wallet at `~/.bittensor/wallets/<coldkey>/hotkeys/<hotkey>`.
#
# Security: the wallet files live on the operator's host filesystem, mounted
# READ-ONLY into the container. The audit code reads `secretSeed` from the
# JSON file at runtime to construct a Keypair locally. Nothing is transmitted
# off-box. Same threat model as `btcli` itself.
SET_WEIGHTS_ENABLED=false

# Wallet identifiers — same names you'd pass to `btcli`:
#   --wallet.name <coldkey>   ↔ AUDITOR_COLDKEY_NAME
#   --wallet.hotkey <hotkey>  ↔ AUDITOR_HOTKEY_NAME
# Leave AUDITOR_COLDKEY_NAME blank when SET_WEIGHTS_ENABLED=false.
# AUDITOR_COLDKEY_NAME=
# AUDITOR_HOTKEY_NAME=default

# Where your ~/.bittensor lives on the HOST (the docker mount source).
# Default `~/.bittensor` matches `btcli`'s default. Override only if your
# wallets are stored elsewhere.
# BITTENSOR_WALLET_DIR=~/.bittensor

# Override version_key if your subnet uses a non-zero value. 0 works on most.
# AUDITOR_WEIGHTS_VERSION_KEY=0
